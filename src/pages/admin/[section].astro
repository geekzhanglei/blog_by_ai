---
export const prerender = true;
export function getStaticPaths() {
  return [
    { params: { section: 'release' } },
    { params: { section: 'delete' } },
    { params: { section: 'comments' } },
    { params: { section: 'msg' } },
    { params: { section: 'visit' } },
    { params: { section: 'info' } },
    { params: { section: 'option' } }
  ];
}
const { section } = Astro.params;
return Astro.redirect(`/admin#${section}`);
---
