renderRelease.init = function() {
  const content = document.getElementById('rContent');
  const preview = document.getElementById('rPreview');
  content.addEventListener('input', () => {
    preview.innerHTML = mdParse(content.value);
  });
  document.getElementById('rSubmit').addEventListener('click', async () => {
