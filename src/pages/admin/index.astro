---
// 管理后台 - 纯客户端渲染，不使用 BaseLayout
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || 'https://blog.feroad.com';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<title>管理后台 - 我的博客</title>
<style is:global>
:root{--ink:#172033;--muted:#667085;--soft:#f6f8fb;--line:#dfe5ef;--panel:#fff;--side:#111827;--side2:#1f2937;--brand:#2563eb;--brand2:#0f766e;--danger:#dc2626;--ok:#059669;--shadow:0 12px 30px rgba(15,23,42,.08);--shadow-sm:0 3px 10px rgba(15,23,42,.06);--radius:8px}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","PingFang SC","Microsoft YaHei",sans-serif;color:var(--ink);background:#eef2f7}
body{overflow:hidden}
button,input,textarea,select{font:inherit}
button{cursor:pointer}
a{color:inherit;text-decoration:none}
svg{display:block}
#app{height:100vh;display:grid;grid-template-rows:60px minmax(0,1fr)}

/* Header */
.adm-hd{height:60px;background:#fff;border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;padding:0 22px;color:var(--ink);box-shadow:var(--shadow-sm);z-index:20}
.adm-title{height:36px;display:inline-flex;align-items:center;gap:10px;font-size:16px;font-weight:800;letter-spacing:0;color:#111827}
.adm-title::before{content:"";width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,var(--brand),var(--brand2));box-shadow:0 8px 18px rgba(37,99,235,.2)}
.adm-user{position:relative;display:flex;align-items:center;gap:10px;min-width:0;padding:6px 8px;border:1px solid transparent;border-radius:8px;cursor:pointer}
.adm-user:hover{background:#f8fafc;border-color:var(--line)}
.adm-user img{width:34px;height:34px;border-radius:50%;border:1px solid var(--line);object-fit:cover;background:#f1f5f9}
.adm-user .name{max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:14px;font-weight:700;color:#344054}
.udrop{position:absolute;right:0;top:48px;min-width:148px;background:#fff;border:1px solid var(--line);border-radius:8px;box-shadow:var(--shadow);overflow:hidden;opacity:0;visibility:hidden;transform:translateY(-6px);transition:.16s ease;z-index:200}
.adm-user:hover .udrop{opacity:1;visibility:visible;transform:translateY(0)}
.udrop a{display:block;padding:11px 14px;font-size:14px;color:#344054;font-weight:650}
.udrop a:hover{background:#f2f6ff;color:var(--brand)}
.udrop .divider{height:1px;background:var(--line);margin:4px 0}

/* Layout */
.adm-body{min-height:0;display:grid;grid-template-columns:220px minmax(0,1fr)}
.adm-sb{min-height:0;background:linear-gradient(180deg,var(--side),var(--side2));display:flex;flex-direction:column;border-right:1px solid rgba(255,255,255,.06);transition:grid-template-columns .2s,width .2s;width:220px}
.adm-sb.collapsed{width:68px}
.adm-sb.collapsed .mt,.adm-sb.collapsed .subm{display:none}
.adm-body:has(.adm-sb.collapsed){grid-template-columns:68px minmax(0,1fr)}
.smenu{flex:1;min-height:0;overflow:auto;padding:14px 10px}
.mi,.sti{position:relative;display:flex;align-items:center;gap:10px;min-height:40px;padding:10px 12px;margin:3px 0;border-radius:8px;color:#cbd5e1;font-size:14px;font-weight:700;line-height:1.2;cursor:pointer;transition:background .15s,color .15s}
.mi:hover,.sti:hover{background:rgba(255,255,255,.08);color:#fff}
.mi.on{background:#fff;color:#111827;box-shadow:0 10px 18px rgba(0,0,0,.12)}
.mi svg,.sti svg{width:18px;height:18px;flex:0 0 18px}
.sti::after{content:"";width:7px;height:7px;border-right:2px solid currentColor;border-bottom:2px solid currentColor;transform:rotate(45deg);margin-left:auto;opacity:.65;transition:.15s}
.collapsible.on .sti::after{transform:rotate(-135deg);margin-top:4px}
.subm{display:none;padding:4px 0 6px 28px}
.subm.on{display:block}
.subm .mi{min-height:34px;margin:2px 0;padding:8px 10px;font-size:13px;color:#aab4c2}
.sbt{height:52px;display:flex;align-items:center;justify-content:flex-end;padding:0 18px;border-top:1px solid rgba(255,255,255,.08);color:#94a3b8;transition:.15s}
.sbt:hover{color:#fff;background:rgba(255,255,255,.05)}
.sbt svg{width:20px;height:20px}

/* Content */
.adm-main{min-width:0;min-height:0;overflow:auto;padding:26px;background:linear-gradient(180deg,#f8fafc,#eef2f7)}
.sec{display:none;max-width:1280px;margin:0 auto}
.sec.on{display:block}
.sec::after{content:"";display:block;clear:both}
.tips{display:flex;align-items:center;min-height:48px;margin:0 0 18px;padding:12px 16px;background:#fff;border:1px solid var(--line);border-left:4px solid var(--brand);border-radius:8px;box-shadow:var(--shadow-sm);font-size:15px;font-weight:800;color:#1f2937}
.tips::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--brand);margin-right:10px}

/* Forms */
.fg{margin-bottom:18px;background:#fff;border:1px solid var(--line);border-radius:8px;padding:16px;box-shadow:var(--shadow-sm)}
.fg label{display:block;margin-bottom:8px;font-size:13px;font-weight:800;color:#344054}
.fg input,.fg textarea,.fg select{width:100%;min-height:42px;padding:10px 12px;border:1px solid #cfd8e6;border-radius:8px;background:#fff;color:#172033;font-size:14px;line-height:1.55;transition:border-color .15s,box-shadow .15s}
.fg textarea{resize:vertical}
.fg input:focus,.fg textarea:focus,.fg select:focus{outline:none;border-color:var(--brand);box-shadow:0 0 0 3px rgba(37,99,235,.12)}
.fg input[type=file]{padding:9px;background:#f8fafc}
.field-note{margin-top:8px;font-size:12px;line-height:1.5;color:#667085}
.avatar-row{display:flex;align-items:center;gap:16px;flex-wrap:wrap}
.avatar-preview{width:86px;height:86px;border-radius:50%;object-fit:cover;border:1px solid var(--line);background:#f8fafc}
.btn,.btn-g{display:inline-flex;align-items:center;justify-content:center;gap:7px;min-height:38px;padding:9px 16px;border-radius:8px;font-size:14px;font-weight:800;line-height:1;border:1px solid transparent;transition:transform .12s,background .15s,border-color .15s,color .15s}
.btn:disabled,.btn-g:disabled{opacity:.62;cursor:not-allowed;transform:none}
.btn{background:var(--brand);color:#fff;box-shadow:0 8px 18px rgba(37,99,235,.18)}
.btn:hover{background:#1d4ed8;transform:translateY(-1px)}
.btn-g{background:#fff;color:#1f2937;border-color:#cfd8e6}
.btn-g:hover{border-color:var(--brand);color:var(--brand);background:#f2f6ff}
.btn-r{background:var(--danger);box-shadow:0 8px 18px rgba(220,38,38,.16)}
.btn-r:hover{background:#b91c1c}
.btn svg,.btn-g svg{width:15px;height:15px;flex:0 0 15px}

/* Tables */
table{width:100%;min-width:760px;border-collapse:separate;border-spacing:0;background:#fff;border:1px solid var(--line);border-radius:8px;box-shadow:var(--shadow-sm);overflow:hidden}
table{display:block;overflow-x:auto}
thead,tbody,tr{display:table;width:100%;table-layout:fixed}
th,td{padding:13px 14px;text-align:left;font-size:14px;vertical-align:top;word-break:break-word}
th{position:sticky;top:0;background:#f8fafc;font-size:12px;letter-spacing:.02em;text-transform:uppercase;color:#667085;font-weight:900;border-bottom:1px solid var(--line);z-index:1}
td{border-bottom:1px solid #edf1f7;color:#344054;line-height:1.55}
tbody tr:last-child td{border-bottom:none}
tbody tr:hover td{background:#fbfdff}
.tac{display:flex;gap:8px;justify-content:flex-end;align-items:center;flex-wrap:wrap}

/* Pagination */
.pg{display:flex;justify-content:center;align-items:center;gap:6px;min-height:38px;margin:20px 0 4px;flex-wrap:wrap}
.pg button{min-width:36px;height:36px;padding:0 12px;border:1px solid #cfd8e6;background:#fff;border-radius:8px;color:#344054;font-size:13px;font-weight:800;transition:.15s}
.pg button:hover{border-color:var(--brand);color:var(--brand);background:#f2f6ff}
.pg button.on{background:var(--brand);color:#fff;border-color:var(--brand)}
.pg button:disabled{opacity:.45;cursor:not-allowed;background:#f8fafc;color:#98a2b3}

/* Markdown */
.md-editor{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:14px;min-height:480px}
.md-editor textarea{min-height:480px;font-family:"SFMono-Regular",Consolas,"Liberation Mono",Menlo,monospace;line-height:1.7}
.md-preview{min-height:480px;padding:16px;background:#fbfdff;border:1px solid #cfd8e6;border-radius:8px;overflow:auto;color:#344054;line-height:1.75}
.md-preview h1,.md-preview h2,.md-preview h3{margin:18px 0 8px;color:#111827}
.md-preview p{margin:8px 0}
.md-preview pre{background:#111827;color:#e5e7eb;padding:14px;border-radius:8px;overflow:auto}
.md-preview code{background:#eef2f7;padding:2px 6px;border-radius:6px;font-size:.92em}
.md-preview blockquote{border-left:4px solid var(--brand);padding:8px 0 8px 14px;color:#667085;background:#f8fafc;margin:12px 0}
.md-preview img{max-width:100%;border-radius:8px;border:1px solid var(--line)}
.md-preview ul,.md-preview ol{padding-left:22px;margin:8px 0}

/* Toast */
#toast{position:fixed;top:74px;right:22px;z-index:9999;width:min(360px,calc(100vw - 32px))}
.toast-item{padding:12px 14px;border-radius:8px;margin-bottom:10px;font-size:14px;font-weight:800;box-shadow:var(--shadow);animation:slideIn .25s ease;cursor:pointer;border:1px solid transparent;background:#fff}
.toast-item.ok{color:#065f46;border-color:#a7f3d0;background:#ecfdf5}
.toast-item.err{color:#991b1b;border-color:#fecaca;background:#fef2f2}
@keyframes slideIn{from{transform:translateX(16px);opacity:0}to{transform:translateX(0);opacity:1}}

/* Dialog */
.modal{position:fixed;inset:0;background:rgba(15,23,42,.48);display:flex;align-items:center;justify-content:center;padding:18px;z-index:500;opacity:0;visibility:hidden;transition:.16s}
.modal.on{opacity:1;visibility:visible}
.modal-box{background:#fff;border:1px solid var(--line);border-radius:8px;padding:20px;max-width:420px;width:100%;box-shadow:0 24px 60px rgba(15,23,42,.22);transform:translateY(8px);transition:.16s}
.modal.on .modal-box{transform:translateY(0)}
.modal-title{font-size:17px;font-weight:900;color:#111827;margin-bottom:8px}
.modal-text{font-size:14px;color:#667085;line-height:1.6;margin-bottom:18px}
.modal-btns{display:flex;gap:10px;justify-content:flex-end}

/* Msg card */
.msg-card{background:#fff;border:1px solid var(--line);border-radius:8px;padding:16px;margin-bottom:14px;box-shadow:var(--shadow-sm)}
.msg-card .meta{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;margin-bottom:10px;font-size:13px;color:#667085;font-weight:700}
.msg-card .content{color:#344054;line-height:1.7;margin-bottom:10px;white-space:pre-wrap}
.msg-card .replies{background:#f8fafc;border:1px solid #edf1f7;border-radius:8px;padding:8px 12px;margin-top:10px}
.msg-card .reply-item{padding:8px 0;border-bottom:1px solid #e5eaf2;font-size:13px;color:#475467;line-height:1.6}
.msg-card .reply-item:last-child{border:none}
.empty{padding:28px;text-align:center;color:#94a3b8;background:#fff;border:1px dashed #cfd8e6;border-radius:8px}
.meta-pill{display:inline-flex;align-items:center;gap:6px;margin-right:10px;color:#475467}
.cell-muted{color:#667085;font-size:12px}
.content-cell{display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}

/* Visit statistics */
.stats-head{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap}
.stats-range{display:inline-flex;gap:6px;padding:4px;background:#e8eef8;border:1px solid #d5deec;border-radius:8px}
.stats-range button{min-height:32px;padding:7px 12px;border:0;border-radius:6px;background:transparent;color:#475467;font-size:13px;font-weight:850}
.stats-range button.on{background:#fff;color:var(--brand);box-shadow:var(--shadow-sm)}
.stats-state{min-height:20px;color:#667085;font-size:13px;font-weight:750}
.stats-state.err{color:var(--danger)}
.stats-metrics{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-bottom:16px}
.stat-metric{min-height:112px;padding:18px;background:#fff;border:1px solid var(--line);border-radius:8px;box-shadow:var(--shadow-sm)}
.stat-metric span{display:block;color:#667085;font-size:13px;font-weight:800}
.stat-metric strong{display:block;margin-top:14px;color:#111827;font-size:32px;line-height:1;font-weight:950}
.stats-grid{display:grid;grid-template-columns:minmax(0,1.7fr) minmax(320px,1fr);gap:14px}
.stats-panel{min-width:0;padding:18px;background:#fff;border:1px solid var(--line);border-radius:8px;box-shadow:var(--shadow-sm)}
.stats-panel h3{margin-bottom:14px;color:#111827;font-size:15px;font-weight:900}
.trend-legend{display:flex;align-items:center;gap:14px;margin-bottom:10px;color:#475467;font-size:12px;font-weight:850}
.trend-legend span{display:inline-flex;align-items:center;gap:6px}
.trend-legend i{display:block;width:12px;height:3px;border-radius:999px;background:var(--swatch)}
.trend-chart{display:block;width:100%;height:auto;min-height:250px;color:#667085}
.trend-chart text{fill:currentColor;font-size:11px;font-weight:750}
.trend-chart .grid{stroke:#dfe5ef;stroke-width:1}
.trend-chart .axis{stroke:#c7d2e3;stroke-width:1.2}
.trend-chart .pv{fill:none;stroke:#2563eb;stroke-width:3;stroke-linecap:round;stroke-linejoin:round}
.trend-chart .uv{fill:none;stroke:#0f766e;stroke-width:3;stroke-linecap:round;stroke-linejoin:round}
.trend-chart .pv-dot{fill:#2563eb}
.trend-chart .uv-dot{fill:#0f766e}
.top-pages{display:grid;gap:13px}
.top-row{display:grid;gap:7px}
.top-copy{display:flex;justify-content:space-between;gap:10px;align-items:flex-start;color:#344054;font-size:13px;font-weight:800}
.top-path{min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.top-count{flex:0 0 auto;color:#667085;font-size:12px}
.top-track{height:10px;border-radius:999px;background:#e8eef8;overflow:hidden}
.top-fill{height:100%;min-width:4px;border-radius:inherit;background:linear-gradient(90deg,var(--brand),var(--brand2))}
.stats-empty{display:flex;align-items:center;justify-content:center;min-height:250px;padding:18px;border:1px dashed #cfd8e6;border-radius:8px;color:#94a3b8;font-size:14px;font-weight:750;text-align:center}

@media (max-width:960px){
  #app{grid-template-rows:56px minmax(0,1fr)}
  .adm-hd{height:56px;padding:0 14px}
  .adm-body{grid-template-columns:72px minmax(0,1fr)}
  .adm-sb{width:72px}
  .adm-sb .mt,.adm-sb .subm,.sti::after{display:none}
  .mi,.sti{justify-content:center;padding:11px 0}
  .adm-main{padding:18px}
  .md-editor{grid-template-columns:1fr}
  .md-editor textarea,.md-preview{min-height:320px}
  .stats-metrics{grid-template-columns:repeat(2,minmax(0,1fr))}
  .stats-grid{grid-template-columns:1fr}
}
@media (max-width:640px){
  body{overflow:auto}
  #app{min-height:100vh;height:auto}
  .adm-body{display:block}
  .adm-sb{width:100%;height:auto;display:block}
  .smenu{display:flex;gap:8px;overflow:auto;padding:10px}
  .mi,.sti{min-width:48px;white-space:nowrap;margin:0}
  .sbt{display:none}
  .adm-main{padding:14px}
  .fg{padding:14px;margin-bottom:14px}
  table{min-width:640px}
  .adm-user .name{display:none}
  .stats-metrics{grid-template-columns:1fr}
  .stat-metric{min-height:94px}
}
</style>
</head>
<body>
<div id="app">
  <header class="adm-hd">
    <a href="/" class="adm-title">传送门</a>
    <div class="adm-user" id="userBox">
      <img id="userImg" src="/default-avatar.svg" alt="avatar" onerror="this.src='/default-avatar.svg'">
      <span class="name" id="userName">管理员</span>
      <div class="udrop">
        <a href="javascript:void(0)" data-sec="info">设置</a>
        <div class="divider"></div>
        <a href="javascript:void(0)" id="logoutBtn">退出登录</a>
      </div>
    </div>
  </header>
  <div class="adm-body">
    <aside class="adm-sb" id="sidebar">
      <div class="smenu" id="menu"></div>
      <div class="sbt" id="toggleSb">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 17l-5-5 5-5M18 17l-5-5 5-5"/></svg>
      </div>
    </aside>
    <main class="adm-main" id="main"></main>
  </div>
</div>

<div id="toast"></div>

<div class="modal" id="modal">
  <div class="modal-box">
    <div class="modal-title" id="modalTitle">确认</div>
    <div class="modal-text" id="modalText">确定执行此操作吗？</div>
    <div class="modal-btns">
      <button class="btn-g" id="modalCancel">取消</button>
      <button class="btn" id="modalOk">确定</button>
    </div>
  </div>
</div>

<script>
const API = 'https://blog.feroad.com';
let adminInfo = { nickname: '管理员', headimg: '/default-avatar.svg' };
let currentSection = 'release';
let sidebarCollapsed = false;

const menuData = [
  { id: 'info', text: '个人信息', icon: 'user' },
  { id: 'admin', text: '文章管理', icon: 'doc', children: [
    { id: 'release', text: '发表文章' },
    { id: 'delete', text: '删除文章' }
  ]},
  { id: 'comments', text: '评论管理', icon: 'comment' },
  { id: 'msg', text: '动态管理', icon: 'msg' },
  { id: 'visit', text: '访问统计', icon: 'chart' },
  { id: 'option', text: '常用选项', icon: 'gear' }
];

// ====== Icons ======
const icons = {
  user: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
  doc: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>',
  comment: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>',
  msg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
  chart: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M7 16l4-5 4 3 5-8"/></svg>',
  gear: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>',
  edit: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>',
  trash: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>',
  eye: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>',
  check: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>',
  x: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'
};

// ====== API Helpers ======
function getToken() {
  return '';
}

function api(url, opts = {}) {
  const token = getToken();
  const isForm = opts.body instanceof FormData;
  const headers = isForm ? {} : { 'Content-Type': 'application/x-www-form-urlencoded' };
  if (token) headers['Authorization'] = `Bearer ${token}`;
  if (opts.headers) Object.assign(headers, opts.headers);

  let body = opts.body;
  if (body && typeof body === 'object' && !(body instanceof FormData) && !(body instanceof URLSearchParams)) {
    body = new URLSearchParams(body);
  }

  return fetch(`${API}${url}`, { ...opts, headers, body, credentials: 'same-origin' }).then(r => r.json());
}

function get(url, params) {
  const query = { ...(params || {}) };
  const token = getToken();
  if (token && !query.token) query.token = token;
  const qs = '?' + new URLSearchParams(query);
  return api(url + qs, { method: 'GET' });
}

function post(url, data) {
  const token = getToken();
  let body = data || {};
  if (body instanceof FormData) {
    if (token && !body.has('token')) body.append('token', token);
  } else if (token && !body.token) {
    body = { ...body, token };
  }
  return api(url, { method: 'POST', body });
}

function uploadImg(file) {
  const fd = new FormData();
  fd.append('file', file);
  return fetch('/api/upload', { method: 'POST', body: fd }).then(r => r.json());
}

function normalizeImageUrl(src) {
  if (!src) return '/default-avatar.svg';
  const value = String(src).trim();
  if (!value) return '/default-avatar.svg';
  if (value.startsWith('http://')) return value.replace('http://', 'https://');
  if (value.startsWith('https://') || value.startsWith('data:') || value.startsWith('blob:')) return value;
  return value.startsWith('/') ? value : `/${value}`;
}

function imageUploadUrl(res) {
  return normalizeImageUrl(res?.result?.data || res?.imgUrl || res?.url || res?.result?.img || '');
}

function escapeHtml(value) {
  return String(value ?? '').replace(/[&<>"']/g, ch => ({
    '&': '&amp;',
    '<': '&lt;',
    '>': '&gt;',
    '"': '&quot;',
    "'": '&#39;'
  }[ch]));
}

function formatDate(value) {
  if (!value) return '-';
  const time = typeof value === 'number' ? value * 1000 : Date.parse(value);
  if (!Number.isFinite(time)) return '-';
  return new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit'
  }).format(new Date(time));
}

function totalRows(result) {
  return Number(result?.rows || result?.count || 0);
}

// ====== UI Helpers ======
function toast(msg, type = 'ok') {
  const el = document.createElement('div');
  el.className = `toast-item ${type}`;
  el.textContent = msg;
  el.onclick = () => el.remove();
  document.getElementById('toast').appendChild(el);
  setTimeout(() => el.remove(), 3000);
}

function confirmDialog(title, text, onOk) {
  document.getElementById('modalTitle').textContent = title;
  document.getElementById('modalText').textContent = text;
  const modal = document.getElementById('modal');
  modal.classList.add('on');

  const ok = document.getElementById('modalOk');
  const cancel = document.getElementById('modalCancel');

  const cleanup = () => {
    modal.classList.remove('on');
    ok.onclick = null;
    cancel.onclick = null;
  };

  ok.onclick = () => { cleanup(); onOk(); };
  cancel.onclick = cleanup;
  modal.onclick = (e) => { if (e.target === modal) cleanup(); };
}

// ====== Sidebar ======
function renderMenu() {
  const menu = document.getElementById('menu');
  menu.innerHTML = menuData.map(item => {
    if (item.children) {
      const isOpen = item.children.some(c => c.id === currentSection);
      return `<div class="collapsible ${isOpen ? 'on' : ''}" data-id="${item.id}">
        <div class="sti"><span class="mt">${item.text}</span></div>
        <div class="subm ${isOpen ? 'on' : ''}">${item.children.map(c =>
          `<a class="mi ${c.id === currentSection ? 'on' : ''}" data-sec="${c.id}" href="javascript:void(0)"><span class="mt">${c.text}</span></a>`
        ).join('')}</div>
      </div>`;
    }
    return `<a class="mi ${item.id === currentSection ? 'on' : ''}" data-sec="${item.id}" href="javascript:void(0)">${icons[item.icon] || ''}<span class="mt">${item.text}</span></a>`;
  }).join('');

  menu.querySelectorAll('[data-sec]').forEach(el => {
    el.addEventListener('click', () => navigate(el.dataset.sec));
  });

  menu.querySelectorAll('.collapsible').forEach(el => {
    el.querySelector('.sti').addEventListener('click', () => {
      el.classList.toggle('on');
      el.querySelector('.subm').classList.toggle('on');
    });
  });
}

// ====== Navigation ======
function navigate(sec) {
  currentSection = sec;
  window.location.hash = sec;
  renderMenu();
  renderPage();
}

function renderPage() {
  const main = document.getElementById('main');
  const renderers = {
    release: renderRelease,
    delete: renderDelete,
    comments: renderComments,
    msg: renderMsg,
    visit: renderVisit,
    info: renderInfo,
    option: renderOption
  };
  const fn = renderers[currentSection] || renderRelease;
  main.innerHTML = fn();
  if (typeof fn.init === 'function') setTimeout(fn.init, 0);
}

