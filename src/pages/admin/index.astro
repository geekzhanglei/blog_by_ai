// ====== Visit Statistics Page ======
let visitDays = 30;
let visitRequestVersion = 0;
function renderVisit() {
  return `<div class="sec on">
    <div class="stats-head">
      <div class="tips" style="margin:0">访问统计</div>
      <div class="stats-range" id="visitRanges">
        ${[7, 30, 90].map(days => `<button class="${days === visitDays ? 'on' : ''}" type="button" data-days="${days}">${days} 天</button>`).join('')}
      </div>
    </div>
    <div class="stats-state" id="visitState">加载统计中...</div>
    <div class="stats-metrics">
      <div class="stat-metric"><span>今日 PV</span><strong id="visitTodayPv">-</strong></div>
      <div class="stat-metric"><span>今日 UV</span><strong id="visitTodayUv">-</strong></div>
      <div class="stat-metric"><span>区间 PV</span><strong id="visitRangePv">-</strong></div>
      <div class="stat-metric"><span>区间 UV</span><strong id="visitRangeUv">-</strong></div>
    </div>
    <div class="stats-grid">
      <section class="stats-panel">
        <h3>PV / UV 趋势</h3>
        <div class="trend-legend"><span><i style="--swatch:#2563eb"></i>PV</span><span><i style="--swatch:#0f766e"></i>UV</span></div>
        <div id="visitTrend"><div class="stats-empty">加载统计中...</div></div>
      </section>
      <section class="stats-panel">
        <h3>热门页面 Top 10</h3>
        <div id="visitTopPages"><div class="stats-empty">加载统计中...</div></div>
      </section>
    </div>
  </div>`;
}
renderVisit.init = function() {
  document.querySelectorAll('#visitRanges [data-days]').forEach(btn => {
    btn.addEventListener('click', () => {
      const days = Number(btn.dataset.days);
      if (days === visitDays) return;
      visitDays = days;
      renderPage();
    });
  });
  loadVisitStats();
};

function formatMetric(value) {
  return new Intl.NumberFormat('zh-CN').format(Number(value || 0));
}

function visitDayKey(date) {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}

function fillVisitTrend(rows, days) {
  const values = new Map((rows || []).map(row => [row.date, row]));
  const today = new Date();
  today.setHours(12, 0, 0, 0);
  const trend = [];
  for (let offset = days - 1; offset >= 0; offset--) {
    const date = new Date(today);
    date.setDate(today.getDate() - offset);
    const key = visitDayKey(date);
    const row = values.get(key) || {};
    trend.push({ date: key, pv: Number(row.pv || 0), uv: Number(row.uv || 0) });
  }
  return trend;
}

function trendLine(data, key, x, y, className) {
  const points = data.map((item, index) => `${x(index)},${y(item[key])}`).join(' ');
  const dots = data.length <= 30 ? data.map((item, index) =>
    `<circle class="${className}-dot" cx="${x(index)}" cy="${y(item[key])}" r="2.8"></circle>`
  ).join('') : '';
  return `<polyline class="${className}" points="${points}"></polyline>${dots}`;
}

function renderTrendChart(data) {
  const width = 760;
  const height = 280;
  const pad = { top: 18, right: 18, bottom: 42, left: 48 };
  const graphWidth = width - pad.left - pad.right;
  const graphHeight = height - pad.top - pad.bottom;
  const maxValue = Math.max(1, ...data.flatMap(item => [item.pv, item.uv]));
  const x = index => pad.left + (data.length === 1 ? graphWidth / 2 : graphWidth * index / (data.length - 1));
  const y = value => pad.top + graphHeight - graphHeight * Number(value || 0) / maxValue;
  const grid = [0, .25, .5, .75, 1].map(rate => {
    const value = Math.round(maxValue * rate);
    const cy = y(value);
    return `<line class="grid" x1="${pad.left}" y1="${cy}" x2="${width - pad.right}" y2="${cy}"></line><text x="${pad.left - 10}" y="${cy + 4}" text-anchor="end">${value}</text>`;
  }).join('');
  const labelIndexes = [...new Set([0, Math.floor((data.length - 1) / 2), data.length - 1])];
  const labels = labelIndexes.map(index =>
    `<text x="${x(index)}" y="${height - 14}" text-anchor="${index === 0 ? 'start' : index === data.length - 1 ? 'end' : 'middle'}">${escapeHtml(data[index].date.slice(5))}</text>`
  ).join('');

  return `<svg class="trend-chart" viewBox="0 0 ${width} ${height}" role="img" aria-label="PV 和 UV 访问趋势">
    ${grid}
    <line class="axis" x1="${pad.left}" y1="${pad.top + graphHeight}" x2="${width - pad.right}" y2="${pad.top + graphHeight}"></line>
    ${trendLine(data, 'pv', x, y, 'pv')}
    ${trendLine(data, 'uv', x, y, 'uv')}
    ${labels}
  </svg>`;
}

function renderTopPages(rows) {
  if (!rows || !rows.length) return '<div class="stats-empty">这个区间还没有访问数据</div>';
  const maxPv = Math.max(1, ...rows.map(row => Number(row.pv || 0)));
  return `<div class="top-pages">${rows.map(row => {
    const pct = Math.max(2, Math.round(Number(row.pv || 0) / maxPv * 100));
    const article = row.articleId ? ` · 文章 #${row.articleId}` : '';
    return `<div class="top-row">
      <div class="top-copy"><span class="top-path" title="${escapeHtml(row.path)}">${escapeHtml(row.path)}${article}</span><span class="top-count">${formatMetric(row.pv)} PV · ${formatMetric(row.uv)} UV</span></div>
      <div class="top-track"><div class="top-fill" style="width:${pct}%"></div></div>
    </div>`;
  }).join('')}</div>`;
}

function setVisitState(text, isError = false) {
  const state = document.getElementById('visitState');
  if (!state) return;
  state.textContent = text;
  state.classList.toggle('err', isError);
}

async function loadVisitStats() {
  const version = ++visitRequestVersion;
  setVisitState('加载统计中...');
  const res = await get('/blogapi/admin/visit/stats', { days: visitDays }).catch(() => null);
  if (version !== visitRequestVersion) return;
  const data = res && res.result;
  if (!data || !data.status) {
    const msg = data && data.msg ? data.msg : '统计加载失败';
    setVisitState(msg, true);
    document.getElementById('visitTrend').innerHTML = `<div class="stats-empty">${escapeHtml(msg)}</div>`;
    document.getElementById('visitTopPages').innerHTML = `<div class="stats-empty">${escapeHtml(msg)}</div>`;
    return;
  }

  const summary = data.summary || {};
  document.getElementById('visitTodayPv').textContent = formatMetric(summary.todayPv);
  document.getElementById('visitTodayUv').textContent = formatMetric(summary.todayUv);
  document.getElementById('visitRangePv').textContent = formatMetric(summary.rangePv);
  document.getElementById('visitRangeUv').textContent = formatMetric(summary.rangeUv);
  document.getElementById('visitTrend').innerHTML = renderTrendChart(fillVisitTrend(data.trend, data.days || visitDays));
  document.getElementById('visitTopPages').innerHTML = renderTopPages(data.topPages);
  setVisitState(`最近 ${data.days || visitDays} 天`);
}

// ====== Info Page ======
function renderInfo() {
  return `<div class="sec on">
    <div class="tips">个人信息设置</div>
    <div class="fg"><label>昵称</label><input type="text" id="iName" value="${adminInfo.nickname || ''}"></div>
    <div class="fg"><label>头像</label><div class="avatar-row"><img id="iPreview" class="avatar-preview" src="${adminInfo.headimg || '/default-avatar.svg'}" alt="头像预览" onerror="this.src='/default-avatar.svg'"><input type="file" id="iImg" accept="image/*"></div><div class="field-note">选择新头像后点击保存，后台会同步更新右上角头像。</div></div>
    <div class="fg"><label>旧密码</label><input type="password" id="iOldPw" placeholder="不修改密码请留空"></div>
    <div class="fg"><label>新密码</label><input type="password" id="iNewPw" placeholder="不修改密码请留空"></div>
    <div><button class="btn" id="iSubmit">保存修改</button></div>
  </div>`;
}
renderInfo.init = function() {
  let selectedAvatarFile = null;
  document.getElementById('iImg').addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;
    selectedAvatarFile = file;
    document.getElementById('iPreview').src = URL.createObjectURL(file);
  });
  document.getElementById('iSubmit').addEventListener('click', async () => {
    const nickname = document.getElementById('iName').value.trim();
    const oldPw = document.getElementById('iOldPw').value;
    const newPw = document.getElementById('iNewPw').value;
    const submit = document.getElementById('iSubmit');
    if (!nickname) { toast('昵称不能为空', 'err'); return; }
    submit.disabled = true;

    if (selectedAvatarFile) {
      const uploadRes = await uploadImg(selectedAvatarFile);
      const uploadedAvatar = imageUploadUrl(uploadRes);
      if (!uploadedAvatar || uploadedAvatar === '/default-avatar.svg') {
        toast('头像上传失败', 'err');
        submit.disabled = false;
        return;
      }
      const infoRes = await post('/blogapi/admin/modifyAdminInfo', { nickname, headimg: uploadedAvatar });
      if (infoRes.result && infoRes.result.status) {
        adminInfo.nickname = nickname;
        adminInfo.headimg = uploadedAvatar;
        document.getElementById('userName').textContent = nickname;
        document.getElementById('userImg').src = adminInfo.headimg;
        document.getElementById('iPreview').src = adminInfo.headimg;
        document.getElementById('iImg').value = '';
        selectedAvatarFile = null;
        toast('头像和昵称已保存');
      } else {
        toast(infoRes.result?.msg || '信息保存失败', 'err');
      }
    } else if (nickname !== adminInfo.nickname) {
      const infoRes = await post('/blogapi/admin/modifyAdminInfo', { nickname });
      if (infoRes.result && infoRes.result.status) {
        adminInfo.nickname = nickname;
        document.getElementById('userName').textContent = nickname;
        toast('昵称已保存');
      } else {
        toast(infoRes.result?.msg || '昵称保存失败', 'err');
      }
    }

    if (oldPw && newPw) {
      const pwRes = await post('/blogapi/admin/modifypw', { password: oldPw, newpassword: newPw });
      if (pwRes.result && pwRes.result.status) {
        toast('密码修改成功');
        document.getElementById('iOldPw').value = '';
        document.getElementById('iNewPw').value = '';
      } else {
        toast(pwRes.result?.msg || '密码修改失败', 'err');
      }
    }
    submit.disabled = false;
  });
};

// ====== Option Page ======
function renderOption() {
  return `<div class="sec on">
    <div class="tips">系统设置</div>
    <div class="fg"><label>文章默认每页条数</label><input type="number" id="oArtPages" placeholder="10"></div>
    <div class="fg"><label>评论默认每页条数</label><input type="number" id="oCommPages" placeholder="10"></div>
    <div class="fg"><label>文章评论默认昵称</label><input type="text" id="oArticleCommName" placeholder="匿名"></div>
    <div class="fg"><label>微言大义默认昵称</label><input type="text" id="oCommName" placeholder="匿名"></div>
    <div class="fg"><label>微言大义回复默认昵称</label><input type="text" id="oReplyName" placeholder="匿名"></div>
    <div><button class="btn" id="oSubmit">保存设置</button></div>
  </div>`;
}
renderOption.init = function() {
  get('/blogapi/admin/options').then(res => {
    if (res.result && res.result.status) {
      const d = res.result || {};
      document.getElementById('oArtPages').value = d.articlePerPage || '';
      document.getElementById('oCommPages').value = d.msgPerPage || '';
      document.getElementById('oArticleCommName').value = d.articleCommentName || '';
      document.getElementById('oCommName').value = d.msgName || '';
      document.getElementById('oReplyName').value = d.msgReplyName || '';
    }
  });
  document.getElementById('oSubmit').addEventListener('click', async () => {
    const artPages = document.getElementById('oArtPages').value;
    const commPages = document.getElementById('oCommPages').value;
    const articleCommName = document.getElementById('oArticleCommName').value;
    const commName = document.getElementById('oCommName').value;
    const replyName = document.getElementById('oReplyName').value;

    const r1 = await post('/blogapi/admin/setDefaultArticlePages', { ispage: 'true', perpage: artPages });
    const r2 = await post('/blogapi/admin/setDefaultCommentInfos', {
      ispage: 'true',
      perpage: commPages,
      defaultArticleCommentName: articleCommName,
      defaultCommentName: commName,
      defaultReplyName: replyName
    });

    if ((r1.result && r1.result.status) && (r2.result && r2.result.status)) {
      toast('设置保存成功');
    } else {
      toast('设置保存失败', 'err');
    }
  });
};

// ====== Markdown Parser ======
function mdParse(text) {
  if (!text) return '';
  return text
    .replace(/^### (.*$)/gim, '<h3>$1</h3>')
    .replace(/^## (.*$)/gim, '<h2>$1</h2>')
    .replace(/^# (.*$)/gim, '<h1>$1</h1>')
    .replace(/\*\*(.*)\*\*/gim, '<strong>$1</strong>')
    .replace(/\*(.*)\*/gim, '<em>$1</em>')
    .replace(/~~(.*)~~/gim, '<del>$1</del>')
    .replace(/```([\s\S]*?)```/gim, '<pre><code>$1</code></pre>')
    .replace(/`([^`]+)`/gim, '<code>$1</code>')
    .replace(/^\> (.*$)/gim, '<blockquote>$1</blockquote>')
    .replace(/!\[([^\]]*)\]\(([^)]+)\)/gim, '<img alt="$1" src="$2">')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/gim, '<a href="$2">$1</a>')
    .replace(/^\- (.*$)/gim, '<ul><li>$1</li></ul>')
    .replace(/^\d+\. (.*$)/gim, '<ol><li>$1</li></ol>')
    .replace(/\n/gim, '<br>');
}

// ====== Auth & Init ======
async function checkLogin() {
  const res = await get('/blogapi/admin/isLogin', {});
  if (!res.result || !res.result.status) { window.location.href = '/login'; return false; }
  return true;
}

async function getAdminInfo() {
  const res = await get('/blogapi/admin/adminInfo', {});
  if (res.result && res.result.status) {
    const data = res.result.data;
    adminInfo.nickname = data.nickname || '管理员';
    adminInfo.headimg = normalizeImageUrl(data.head_img);
    document.getElementById('userName').textContent = adminInfo.nickname;
    document.getElementById('userImg').src = adminInfo.headimg;
    document.getElementById('userImg').onerror = () => {
      document.getElementById('userImg').src = '/default-avatar.svg';
    };
  }
}

document.getElementById('logoutBtn').addEventListener('click', async () => {
  await get('/blogapi/admin/loginout', {});
  window.location.href = '/login';
});

document.getElementById('toggleSb').addEventListener('click', () => {
  sidebarCollapsed = !sidebarCollapsed;
  document.getElementById('sidebar').classList.toggle('collapsed', sidebarCollapsed);
});

// Hash routing
window.addEventListener('hashchange', () => {
  const hash = window.location.hash.replace('#', '') || 'release';
  if (hash !== currentSection) {
    currentSection = hash;
    renderMenu();
    renderPage();
  }
});

// Init
checkLogin().then(ok => {
  if (!ok) return;
  getAdminInfo();
  const hash = window.location.hash.replace('#', '') || 'release';
  currentSection = hash;
  renderMenu();
  renderPage();
});
</script>
</body>
