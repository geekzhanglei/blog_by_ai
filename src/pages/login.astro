---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="登录 - 博客管理后台" description="博客管理后台登录" hideChrome>
  <div class="login-page">
    <div class="login-bg"></div>
    <div class="login-container">
      <div class="login-card">
        <div class="login-card__header">
          <div class="login-logo"><span class="logo-icon">✦</span></div>
          <h1 class="login-title">博客管理后台</h1>
          <p class="login-subtitle">登录以管理您的博客内容</p>
        </div>
        <form class="login-card__body" id="login-form">
          <div class="form-group">
            <label class="form-label" for="loginname">用户名</label>
            <input class="login-input" id="loginname" name="username" placeholder="请输入用户名" maxlength="14" type="text" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="loginpwd">密码</label>
            <input class="login-input" id="loginpwd" name="password" placeholder="请输入密码" maxlength="12" type="password" required />
          </div>
          <div class="login-tips" data-login-tip>内测，仅允许管理员登陆</div>
          <div class="login-btns">
            <button class="btn-primary" type="submit">登 录</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.querySelector('#login-form');
  const tip = document.querySelector('[data-login-tip]');
  const submit = form?.querySelector('button[type="submit"]');
  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const data = new FormData(form);
    if (tip) {
      tip.classList.remove('error');
      tip.textContent = '登录中…';
    }
    if (submit) {
      submit.disabled = true;
      submit.textContent = '登录中…';
    }
    const response = await fetch('/api/login', { method: 'POST', body: data });
    const json = await response.json().catch(() => null);
    if (json?.result?.status) {
      localStorage.setItem('token', json.result.token || '');
      window.location.href = '/admin';
    } else if (tip) {
      tip.classList.add('error');
      tip.textContent = json?.result?.msg || '账号或密码错误';
    }
    if (submit) {
      submit.disabled = false;
      submit.textContent = '登 录';
    }
  });
</script>
