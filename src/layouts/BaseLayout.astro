---
import globalCss from '../styles/global.css?raw';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  hideChrome?: boolean;
}

const {
  title = '我的博客',
  description = '记录技术成长与思考旅程',
  hideChrome = false
} = Astro.props;
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || 'https://blog.feroad.com';
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <style is:inline set:html={globalCss}></style>
    <script is:inline define:vars={{ apiBase }}>
      window.__BLOG_API_BASE__ = apiBase.replace(/\/$/, '');
    </script>
  </head>
  <body>
    <div id="app-shell" class:list={{ 'app-shell--plain': hideChrome }}>
      {!hideChrome && <Header currentPath={Astro.url.pathname} />}
      <main class="site-main">
        <slot />
      </main>
      {!hideChrome && <Footer />}
    </div>
  </body>
</html>
